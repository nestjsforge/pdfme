{
  "name": "@nestjsforge/pdfme",
  "version": "1.0.2",
  "description": "NestJS integration for PDFMe — generate, validate and manage PDF templates as injectable services",
  "license": "MIT",
  "author": {
    "name": "Smerlyn Eusebio",
    "email": "smerlynjaviereusebiobonifacio@gmail.com"
  },
  "homepage": "https://github.com/nestjsforge/pdfme#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjsforge/pdfme.git"
  },
  "bugs": {
    "url": "https://github.com/nestjsforge/pdfme/issues"
  },
  "keywords": [
    "nestjs",
    "pdfme",
    "pdf",
    "pdf-generator",
    "nestjs-module",
    "typescript"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config jest.e2e.config.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@pdfme/common": "^6.0.0",
    "@pdfme/generator": "^6.0.0",
    "@pdfme/schemas": "^6.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@pdfme/schemas": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/testing": "^11.1.27",
    "@pdfme/common": "^6.1.8",
    "@pdfme/generator": "^6.1.8",
    "@pdfme/schemas": "^6.1.8",
    "@swc/core": "^1.15.41",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "jest": "^29.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
